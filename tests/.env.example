# Copy this file to tests/.env and fill in your Kraken API credentials to run the
# private live tests (`ctest -L live`). tests/.env is gitignored.
#
# The secret is the base64-encoded private key shown when you create an API key
# in the Kraken UI. Give the key read-only permissions (Query Funds / Open &
# Closed Orders / Trades) — the live tests never place or cancel real orders.
KRAKEN_API_KEY=your_api_key_here
KRAKEN_API_SECRET=your_base64_private_key_here
